<% content_for :title, @pav.name %>

<turbo-frame id="pav-panel">
  <div class="flex flex-col h-full bg-gray-900 text-gray-100 min-h-[calc(100vh-3.5rem)] <%= @from_incidents ? "rounded-xl border border-gray-800" : "" %>">

    <%# Header %>
    <div class="flex items-center justify-between px-5 pt-5 pb-4 border-b border-gray-800 flex-shrink-0">
      <div class="flex-1 min-w-0 mr-3">
        <h2 class="font-semibold text-white text-lg truncate"><%= @pav.name %></h2>
        <p class="text-xs text-gray-500 mt-0.5"><%= @pav.pav_id %></p>
        <% if @pav.overfull? %>
          <span class="inline-flex items-center gap-1 mt-1.5 text-xs px-2 py-0.5 rounded-md bg-red-950 border border-red-800 text-red-400">
            <svg class="w-3 h-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
            </svg>
            Seuil critique
          </span>
        <% end %>
      </div>
      <% if @from_incidents %>
        <%= link_to incidents_path, data: { turbo_frame: "_top" }, class: "flex-shrink-0 flex items-center gap-1.5 px-2.5 py-1.5 rounded-lg text-gray-400 hover:text-white hover:bg-gray-800 transition-colors" do %>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
          </svg>
          <span class="text-xs">Incidents</span>
        <% end %>
      <% else %>
        <button
          class="flex-shrink-0 p-1.5 rounded-lg text-gray-400 hover:text-white hover:bg-gray-800 transition-colors cursor-pointer"
          data-action="click->map#closePanel"
          aria-label="Fermer"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      <% end %>
    </div>

    <%# Onglets %>
    <div
      data-controller="tabs"
      data-tabs-active-tab-value="<%= @active_tab %>"
      class="flex flex-col flex-1 min-h-0"
    >

      <div class="flex border-b border-gray-800 px-3 flex-shrink-0">
        <button class="py-3 px-2.5 text-xs border-b-2 transition-colors whitespace-nowrap hover:text-white cursor-pointer" data-tabs-target="tab" data-action="click->tabs#switch">
          Informations
        </button>
        <button class="py-3 px-2.5 text-xs border-b-2 transition-colors whitespace-nowrap hover:text-white cursor-pointer" data-tabs-target="tab" data-action="click->tabs#switch">
          Timeline
        </button>
        <button class="py-3 px-2.5 text-xs border-b-2 transition-colors whitespace-nowrap hover:text-white cursor-pointer" data-tabs-target="tab" data-action="click->tabs#switch">
          Relevés <span class="opacity-50">(<%= @pagy_readings.count %>)</span>
        </button>
        <button class="py-3 px-2.5 text-xs border-b-2 transition-colors whitespace-nowrap hover:text-white cursor-pointer" data-tabs-target="tab" data-action="click->tabs#switch">
          Dépôts <span class="opacity-50">(<%= @pagy_deposits.count %>)</span>
        </button>
        <button class="py-3 px-2.5 text-xs border-b-2 transition-colors whitespace-nowrap hover:text-white cursor-pointer" data-tabs-target="tab" data-action="click->tabs#switch">
          Incidents <span class="opacity-50">(<%= @pagy_incidents.count %>)</span>
        </button>
      </div>

      <%# Onglet 1 : Informations %>
      <div data-tabs-target="panel" class="flex-1 overflow-y-auto px-5 py-5">

        <%# Taux de remplissage en évidence %>
        <% fill = @pav.current_fill_percent %>
        <% if fill %>
          <% fill_f = fill.to_f %>
          <div class="mb-5 bg-gray-800 rounded-xl p-4 border border-gray-700">
            <div class="text-xs text-gray-500 mb-2">Taux de remplissage actuel</div>
            <div class="flex items-end justify-between mb-3">
              <span class="text-4xl font-bold <%= fill_f > 80 ? "text-red-400" : fill_f > 50 ? "text-yellow-400" : "text-green-400" %>">
                <%= fill_f.round %> %
              </span>
              <% if @latest_reading_at %>
                <% days_ago = [((Time.current - @latest_reading_at) / 1.day).floor, 0].max %>
                <% freshness_label = days_ago == 0 ? "Aujourd'hui" : days_ago == 1 ? "Hier" : "il y a #{days_ago} j" %>
                <span class="text-xs mb-1 <%= days_ago >= 7 ? "text-red-400" : "text-gray-500" %>"><%= freshness_label %></span>
              <% end %>
            </div>
            <div class="w-full bg-gray-700 rounded-full h-2">
              <div class="h-2 rounded-full <%= fill_f > 80 ? "bg-red-400" : fill_f > 50 ? "bg-yellow-400" : "bg-green-400" %>" style="width: <%= fill_f.round %>%"></div>
            </div>
          </div>
        <% end %>

        <%# Infos génériques %>
        <dl class="grid grid-cols-2 gap-3 mb-5">
          <div class="bg-gray-800 rounded-xl p-4 border border-gray-700">
            <dt class="text-xs text-gray-500 mb-1">Type de déchet</dt>
            <dd class="text-white font-semibold"><%= @pav.waste_type&.humanize || "—" %></dd>
          </div>
          <div class="bg-gray-800 rounded-xl p-4 border border-gray-700">
            <dt class="text-xs text-gray-500 mb-1">Contenance</dt>
            <dd class="text-white font-semibold"><%= @pav.capacity_liters ? "#{@pav.capacity_liters} L" : "—" %></dd>
          </div>
          <div class="bg-gray-800 rounded-xl p-4 border border-gray-700 col-span-2">
            <dt class="text-xs text-gray-500 mb-1">Adresse</dt>
            <dd class="text-white font-semibold"><%= [@pav.address, @pav.zip, @pav.city].compact.join(", ") %></dd>
          </div>
        </dl>

        <%# Graphique remplissage 30j %>
        <div class="border-t border-gray-800 pt-5">
          <div class="text-xs text-gray-500 mb-3">Remplissage sur 30 jours</div>
          <% if @has_chart_data %>
            <div data-controller="chart" data-chart-data-value="<%= @chart_data %>">
              <canvas data-chart-target="canvas" class="w-full"></canvas>
            </div>
          <% else %>
            <p class="text-sm text-gray-500 text-center py-8">Aucune donnée disponible.</p>
          <% end %>
        </div>

      </div>

      <%# Onglet 2 : Timeline %>
      <div data-tabs-target="panel" class="hidden flex-1 overflow-y-auto px-5 py-4">
        <% if @timeline_logs.any? %>
          <div class="space-y-0 divide-y divide-gray-800">
            <% @timeline_logs.each do |log| %>
              <div class="flex items-start gap-3 py-3">

                <%# Icône par type %>
                <% if log.event_type == "sensor_reading" %>
                  <div class="flex-shrink-0 mt-0.5 w-7 h-7 rounded-lg bg-blue-950 border border-blue-800 flex items-center justify-center">
                    <svg class="w-3.5 h-3.5 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
                    </svg>
                  </div>
                <% elsif log.event_type == "badge_deposit" %>
                  <div class="flex-shrink-0 mt-0.5 w-7 h-7 rounded-lg bg-green-950 border border-green-800 flex items-center justify-center">
                    <svg class="w-3.5 h-3.5 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 9h3.75M15 12h3.75M15 15h3.75M4.5 19.5h15a2.25 2.25 0 002.25-2.25V6.75A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25v10.5A2.25 2.25 0 004.5 19.5zm6-10.125a1.875 1.875 0 11-3.75 0 1.875 1.875 0 013.75 0zm1.294 6.336a6.721 6.721 0 01-3.17.789 6.721 6.721 0 01-3.168-.789 3.376 3.376 0 016.338 0z"/>
                    </svg>
                  </div>
                <% else %>
                  <div class="flex-shrink-0 mt-0.5 w-7 h-7 rounded-lg bg-orange-950 border border-orange-800 flex items-center justify-center">
                    <svg class="w-3.5 h-3.5 text-orange-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
                    </svg>
                  </div>
                <% end %>

                <%# Contenu %>
                <div class="flex-1 min-w-0">
                  <div class="flex items-center justify-between gap-2 mb-0.5">
                    <span class="text-xs text-gray-500"><%= log.occurred_at.strftime("%d/%m/%Y %H:%M") %></span>
                    <% if log.event_type == "sensor_reading" %>
                      <% fill_v = log.payload["fill_percent"]&.to_f %>
                      <%= render "shared/fill_badge", fill: fill_v if fill_v %>
                    <% elsif log.event_type == "badge_deposit" %>
                      <% granted = log.payload["access_granted"] %>
                      <% unless granted.nil? %>
                        <span class="text-xs px-1.5 py-0.5 rounded <%= granted ? "bg-green-950 text-green-300" : "bg-red-950 text-red-300" %>">
                          <%= granted ? "Accepté" : "Refusé" %>
                        </span>
                      <% end %>
                    <% elsif log.event_type == "incident" %>
                      <%= render "shared/incident_badge", resolved: log.resolved? %>
                    <% end %>
                  </div>
                  <p class="text-xs text-gray-300 truncate">
                    <% if log.event_type == "sensor_reading" %>
                      Relevé capteur
                    <% elsif log.event_type == "badge_deposit" %>
                      <%= log.payload["badge_id"] || "—" %> · <%= log.payload["badge_provider"] || "—" %>
                    <% else %>
                      <%= log.description %>
                    <% end %>
                  </p>
                </div>

              </div>
            <% end %>
          </div>
          <%= render "shared/pagy_nav", pagy: @pagy_timeline, page_param: :page_t, tab_index: 1 %>
        <% else %>
          <p class="text-sm text-gray-500 text-center py-10">Aucun événement.</p>
        <% end %>
      </div>

      <%# Onglet 3 : Relevés capteur %>
      <div data-tabs-target="panel" class="hidden flex-1 overflow-y-auto px-5 py-4">
        <% if @sensor_readings.any? %>
          <% readings_arr = @sensor_readings.to_a %>
          <table class="w-full text-sm">
            <thead>
              <tr class="text-left text-xs text-gray-500 border-b border-gray-800">
                <th class="pb-2 font-medium">Date</th>
                <th class="pb-2 font-medium text-right">Évolution</th>
                <th class="pb-2 font-medium text-right">Remplissage</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-800">
              <% readings_arr.each_with_index do |log, i| %>
                <% fill_val = log.payload["fill_percent"]&.to_f %>
                <% prev_fill = readings_arr[i + 1]&.payload&.dig("fill_percent")&.to_f %>
                <% delta = fill_val && prev_fill ? (fill_val - prev_fill).round : nil %>
                <tr>
                  <td class="py-2 text-gray-400 text-xs"><%= log.occurred_at.strftime("%d/%m/%Y %H:%M") %></td>
                  <td class="py-2 text-right text-xs">
                    <% if delta %>
                      <% if delta > 0 %>
                        <span class="text-red-400">+<%= delta %> %</span>
                      <% elsif delta < 0 %>
                        <span class="text-green-400"><%= delta %> %</span>
                      <% else %>
                        <span class="text-gray-600">—</span>
                      <% end %>
                    <% else %>
                      <span class="text-gray-700">—</span>
                    <% end %>
                  </td>
                  <td class="py-2 text-right">
                    <% if fill_val %>
                      <%= render "shared/fill_badge", fill: fill_val %>
                    <% else %>
                      <span class="text-gray-600">—</span>
                    <% end %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
          <%= render "shared/pagy_nav", pagy: @pagy_readings, page_param: :page_r, tab_index: 2 %>
        <% else %>
          <p class="text-sm text-gray-500 text-center py-10">Aucune lecture capteur.</p>
        <% end %>
      </div>

      <%# Onglet 4 : Dépôts badge %>
      <div data-tabs-target="panel" class="hidden flex-1 overflow-y-auto px-5 py-4">
        <% if @badge_deposits.any? %>
          <table class="w-full text-sm">
            <thead>
              <tr class="text-left text-xs text-gray-500 border-b border-gray-800">
                <th class="pb-2 font-medium">Date</th>
                <th class="pb-2 font-medium">Badge</th>
                <th class="pb-2 font-medium">Prestataire</th>
                <th class="pb-2 font-medium text-right">Statut</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-800">
              <% @badge_deposits.each do |log| %>
                <% granted = log.payload["access_granted"] %>
                <% reasons = log.anomaly_reasons %>
                <tr>
                  <td class="py-2 text-gray-400 text-xs whitespace-nowrap"><%= log.occurred_at.strftime("%d/%m/%Y") %></td>
                  <td class="py-2 text-xs">
                    <span class="font-mono text-gray-400"><%= log.payload["badge_id"] || "—" %></span>
                    <% if reasons.any? %>
                      <div class="text-gray-600 mt-0.5"><%= reasons.join(", ") %></div>
                    <% end %>
                  </td>
                  <td class="py-2 text-gray-500 text-xs"><%= log.payload["badge_provider"] || "—" %></td>
                  <td class="py-2 text-right">
                    <% if granted.nil? %>
                      <span class="text-gray-600 text-xs">—</span>
                    <% elsif granted %>
                      <span class="text-xs px-2 py-0.5 rounded-md bg-green-950 text-green-300">Accepté</span>
                    <% else %>
                      <span class="text-xs px-2 py-0.5 rounded-md bg-red-950 text-red-300">Refusé</span>
                    <% end %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
          <%= render "shared/pagy_nav", pagy: @pagy_deposits, page_param: :page_d, tab_index: 3 %>
        <% else %>
          <p class="text-sm text-gray-500 text-center py-10">Aucun dépôt badge.</p>
        <% end %>
      </div>

      <%# Onglet 5 : Incidents %>
      <div data-tabs-target="panel" class="hidden flex-1 overflow-y-auto px-5 py-4">
        <% if @incidents.any? %>
          <div class="space-y-3">
            <% @incidents.each do |incident| %>
              <div class="bg-gray-800 rounded-lg p-3 border border-gray-700">
                <div class="flex items-center justify-between mb-2">
                  <span class="text-xs text-gray-500"><%= incident.occurred_at.strftime("%d/%m/%Y") %></span>
                  <%= render "shared/incident_badge", resolved: incident.resolved? %>
                </div>
                <p class="text-sm text-gray-200"><%= incident.description %></p>
                <% unless incident.resolved? %>
                  <%= render "shared/confirm_resolve", incident: incident, wrapper_class: "mt-3", button_label: "Marquer comme résolu" %>
                <% end %>
              </div>
            <% end %>
          </div>
          <%= render "shared/pagy_nav", pagy: @pagy_incidents, page_param: :page_i, tab_index: 4 %>
        <% else %>
          <p class="text-sm text-gray-500 text-center py-10">Aucun incident.</p>
        <% end %>
      </div>

    </div>
  </div>
</turbo-frame>
