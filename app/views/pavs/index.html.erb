<% content_for :main_class, "relative overflow-hidden" %>
<% content_for :title, "Vigie" %>

<div
  class="relative h-[calc(100vh-3.5rem)]"
  data-controller="map"
  data-map-pavs-value="<%= @pavs_json %>"
>

  <%# Leaflet map %>
  <div id="map" class="absolute inset-0 z-0"></div>

  <%# Recherche — overlay haut centre %>
  <div class="absolute top-4 left-1/2 -translate-x-1/2 z-10 w-72">
    <div class="flex items-center gap-2 bg-white/10 backdrop-blur-sm border border-white/25 rounded-xl px-3 py-1.5 shadow-lg hover:bg-gray-900/90 hover:border-gray-700 transition-all duration-300 group">
      <svg class="w-3.5 h-3.5 text-white/50 group-hover:text-gray-500 flex-shrink-0 transition-colors duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
      </svg>
      <input
        type="text"
        placeholder="Rechercher un pav"
        class="bg-transparent text-sm text-white placeholder-gray-600 outline-none w-full"
        data-action="keydown.enter->map#search"
        data-map-target="searchInput"
      >
    </div>
  </div>

  <%# Stats — overlay haut gauche %>
  <div class="absolute top-4 left-4 z-10 flex gap-2">

    <div class="bg-gray-900/90 backdrop-blur-sm border border-gray-800 rounded-2xl px-4 py-3.5 shadow-xl">
      <div class="flex items-center gap-1.5 mb-2">
        <svg class="w-3.5 h-3.5 text-blue-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
        </svg>
        <span class="text-xs text-gray-500 font-medium tracking-wide">PAVs</span>
      </div>
      <div class="text-2xl font-bold text-white tabular-nums leading-none" data-map-target="statPavs"><%= @total_pavs %></div>
    </div>

    <div class="bg-gray-900/90 backdrop-blur-sm border border-gray-800 rounded-2xl px-4 py-3.5 shadow-xl">
      <div class="flex items-center gap-1.5 mb-2">
        <svg class="w-3.5 h-3.5 text-green-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
        </svg>
        <span class="text-xs text-gray-500 font-medium tracking-wide">Remplissage moy.</span>
      </div>
      <div class="text-2xl font-bold text-white tabular-nums leading-none" data-map-target="statFill"><%= @avg_fill ? "#{@avg_fill} %" : "—" %></div>
    </div>

    <div class="bg-gray-900/90 backdrop-blur-sm border border-gray-800 rounded-2xl px-4 py-3.5 shadow-xl">
      <div class="flex items-center gap-1.5 mb-2">
        <svg class="w-3.5 h-3.5 text-orange-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
        </svg>
        <span class="text-xs text-gray-500 font-medium tracking-wide">Incidents</span>
      </div>
      <div class="text-2xl font-bold tabular-nums leading-none" data-map-target="statIncidents"><%= @open_incidents %></div>
    </div>

  </div>

  <%# Filtres — bas gauche %>
  <div class="absolute bottom-6 left-4 z-10 flex flex-col gap-2 items-start">

    <div class="flex items-center gap-2">

      <%# Filtre type de déchet %>
      <div class="relative" data-controller="dropdown">
        <button
          data-action="click->dropdown#toggle"
          class="flex items-center gap-2 bg-gray-900/90 backdrop-blur-sm border border-gray-700 rounded-full px-3.5 py-2 hover:border-gray-500 transition-colors shadow-lg cursor-pointer"
        >
          <svg class="w-3.5 h-3.5 text-gray-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
          </svg>
          <span class="text-xs text-gray-200" data-dropdown-target="label" data-map-target="wasteTypeLabel">Tous types</span>
          <svg class="w-3 h-3 text-gray-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"/>
          </svg>
        </button>
        <div
          data-dropdown-target="menu"
          class="hidden absolute bottom-full left-0 mb-2 bg-gray-900 border border-gray-700 rounded-xl shadow-2xl overflow-hidden py-1 z-50 min-w-[9rem]"
        >
          <button
            class="w-full text-left px-4 py-2.5 text-xs text-yellow-400 hover:bg-gray-800 transition-colors cursor-pointer"
            data-action="click->dropdown#select"
            data-dropdown-target="option"
            data-value=""
            data-label="Tous types"
          >Tous types</button>
          <% @pavs.map(&:waste_type).uniq.compact.sort.each do |type| %>
            <button
              class="w-full text-left px-4 py-2.5 text-xs text-gray-300 hover:bg-gray-800 hover:text-white transition-colors cursor-pointer"
              data-action="click->dropdown#select"
              data-dropdown-target="option"
              data-value="<%= type %>"
              data-label="<%= type.humanize %>"
            ><%= type.humanize %></button>
          <% end %>
        </div>
        <input
          type="hidden"
          value=""
          data-dropdown-target="input"
          data-map-target="wasteTypeFilter"
          data-action="change->map#filterMarkers"
        >
      </div>

      <%# Filtre niveau de remplissage %>
      <div class="relative" data-controller="dropdown">
        <button
          data-action="click->dropdown#toggle"
          class="flex items-center gap-2 bg-gray-900/90 backdrop-blur-sm border border-gray-700 rounded-full px-3.5 py-2 hover:border-gray-500 transition-colors shadow-lg cursor-pointer"
        >
          <svg class="w-3.5 h-3.5 text-gray-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
          </svg>
          <span class="text-xs text-gray-200" data-dropdown-target="label" data-map-target="fillLevelLabel">Tous niveaux</span>
          <svg class="w-3 h-3 text-gray-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"/>
          </svg>
        </button>
        <div
          data-dropdown-target="menu"
          class="hidden absolute bottom-full left-0 mb-2 bg-gray-900 border border-gray-700 rounded-xl shadow-2xl overflow-hidden py-1 z-50 min-w-[9rem]"
        >
          <button class="w-full text-left px-4 py-2.5 text-xs text-yellow-400 hover:bg-gray-800 transition-colors cursor-pointer" data-action="click->dropdown#select" data-dropdown-target="option" data-value="" data-label="Tous niveaux">Tous niveaux</button>
          <button class="w-full text-left px-4 py-2.5 text-xs text-gray-300 hover:bg-gray-800 hover:text-white transition-colors cursor-pointer" data-action="click->dropdown#select" data-dropdown-target="option" data-value="low" data-label="&lt; 50 %">&lt; 50 %</button>
          <button class="w-full text-left px-4 py-2.5 text-xs text-gray-300 hover:bg-gray-800 hover:text-white transition-colors cursor-pointer" data-action="click->dropdown#select" data-dropdown-target="option" data-value="medium" data-label="50 – 80 %">50 – 80 %</button>
          <button class="w-full text-left px-4 py-2.5 text-xs text-gray-300 hover:bg-gray-800 hover:text-white transition-colors cursor-pointer" data-action="click->dropdown#select" data-dropdown-target="option" data-value="high" data-label="&gt; 80 %">&gt; 80 %</button>
          <button class="w-full text-left px-4 py-2.5 text-xs text-gray-300 hover:bg-gray-800 hover:text-white transition-colors cursor-pointer" data-action="click->dropdown#select" data-dropdown-target="option" data-value="unknown" data-label="Inconnu">Inconnu</button>
        </div>
        <input
          type="hidden"
          value=""
          data-dropdown-target="input"
          data-map-target="fillLevelFilter"
          data-action="change->map#filterMarkers"
        >
      </div>

      <button
        data-map-target="resetBtn"
        data-action="click->map#resetFilters"
        title="Réinitialiser les filtres"
        class="hidden items-center justify-center w-9 h-9 bg-gray-900/90 backdrop-blur-sm border border-gray-700 rounded-full text-gray-400 hover:border-gray-500 hover:text-white transition-colors shadow-lg cursor-pointer"
      >
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/>
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3v5h5"/>
        </svg>
      </button>

    </div>

    <%# Légende %>
    <div class="flex gap-3 text-xs text-gray-400 bg-gray-900/80 backdrop-blur-sm rounded-full px-4 py-1.5 border border-gray-800 shadow">
      <span class="flex items-center gap-1.5"><span class="w-2 h-2 rounded-full bg-green-400 inline-block"></span>&lt; 50 %</span>
      <span class="flex items-center gap-1.5"><span class="w-2 h-2 rounded-full bg-yellow-400 inline-block"></span>50–80 %</span>
      <span class="flex items-center gap-1.5"><span class="w-2 h-2 rounded-full bg-red-400 inline-block"></span>&gt; 80 %</span>
    </div>

  </div>

  <%# Panneau PAV — dépliable depuis la droite %>
  <div
    class="absolute top-0 right-0 h-full w-[30rem] bg-gray-900 border-l border-gray-800 z-20 transform translate-x-full transition-transform duration-300 ease-in-out overflow-y-auto shadow-2xl"
    data-map-target="panel"
  >
    <turbo-frame id="pav-panel"></turbo-frame>
  </div>

</div>
