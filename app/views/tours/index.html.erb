<% content_for :main_class, "relative overflow-hidden" %>
<% content_for :title, "Tournée — Vigie" %>
<% content_for :head do %><meta name="turbo-cache-control" content="no-cache"><% end %>

<div
  class="relative h-[calc(100vh-3.5rem)]"
  data-controller="tour-planner"
  data-tour-planner-pavs-value="<%= @pavs_json %>"
>

  <%# Leaflet map %>
  <div id="route-map" class="absolute inset-0 z-0"></div>

  <%# Panneau de contrôle — gauche %>
  <div class="absolute top-4 left-4 z-10 w-72 bg-gray-900/95 backdrop-blur-sm border border-gray-800 rounded-2xl shadow-2xl overflow-hidden flex flex-col">

    <%# En-tête %>
    <div class="px-4 pt-4 pb-3 border-b border-gray-800">
      <div class="flex items-center gap-2.5">
        <svg class="w-4 h-4 text-violet-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M1 3h15v13H1zM16 8h4l3 3v5h-7V8zM4 17a1.5 1.5 0 103 0a1.5 1.5 0 10-3 0M17 17a1.5 1.5 0 103 0a1.5 1.5 0 10-3 0"/>
        </svg>
        <span class="text-sm font-semibold text-white">Planifier une tournée</span>
      </div>
      <p class="text-xs text-gray-500 mt-1">Cliquez sur un PAV pour l'ajouter ou le retirer</p>
    </div>

    <%# Seuil de remplissage %>
    <div class="px-4 py-3 border-b border-gray-800">
      <div class="flex items-center justify-between mb-2.5">
        <span class="text-xs text-gray-400">Seuil de remplissage</span>
        <span class="text-sm font-bold text-yellow-400 tabular-nums" data-tour-planner-target="thresholdLabel">70 %</span>
      </div>
      <input
        type="range"
        min="50" max="100" step="5" value="70"
        class="w-full h-1.5 accent-yellow-400 cursor-pointer"
        data-tour-planner-target="threshold"
        data-action="input->tour-planner#thresholdChanged"
      >
      <div class="flex justify-between text-xs text-gray-700 mt-1.5">
        <span>50 %</span>
        <span>100 %</span>
      </div>
    </div>

    <%# Statistiques %>
    <div class="px-4 py-3 border-b border-gray-800 grid grid-cols-2 gap-3">
      <div>
        <span class="text-xs text-gray-500 block mb-1">PAVs sélectionnés</span>
        <span class="text-xl font-bold text-white tabular-nums" data-tour-planner-target="count">0</span>
      </div>
      <div>
        <span class="text-xs text-gray-500 block mb-1">Distance estimée</span>
        <span class="text-xl font-bold text-violet-400 tabular-nums" data-tour-planner-target="distance">—</span>
      </div>
    </div>

    <%# Bouton Calculer %>
    <div class="px-4 py-3 border-b border-gray-800">
      <button
        data-tour-planner-target="calculateBtn"
        data-action="click->tour-planner#calculate"
        disabled
        class="w-full py-2 rounded-xl bg-purple-600 hover:bg-purple-500 text-white text-sm font-semibold transition-colors opacity-40 cursor-not-allowed"
      >
        Calculer l'itinéraire
      </button>
    </div>

    <%# Liste de la tournée %>
    <div class="max-h-72 overflow-y-auto px-4 py-1" data-tour-planner-target="routeList">
      <p class="text-xs text-gray-600 text-center py-6">Ajustez le seuil puis cliquez sur Calculer</p>
    </div>

  </div>

  <%# Légende — bas gauche %>
  <div class="absolute bottom-6 left-4 z-10">
    <div class="flex gap-3 text-xs text-gray-400 bg-gray-900/80 backdrop-blur-sm rounded-full px-4 py-1.5 border border-gray-800 shadow">
      <span class="flex items-center gap-1.5"><span class="w-2 h-2 rounded-full bg-green-400 inline-block"></span>&lt; 50 %</span>
      <span class="flex items-center gap-1.5"><span class="w-2 h-2 rounded-full bg-yellow-400 inline-block"></span>50–80 %</span>
      <span class="flex items-center gap-1.5"><span class="w-2 h-2 rounded-full bg-red-400 inline-block"></span>&gt; 80 %</span>
      <span class="flex items-center gap-1.5"><span class="w-2 h-2 rounded-full bg-gray-500 inline-block"></span>Inconnu</span>
    </div>
  </div>

</div>
