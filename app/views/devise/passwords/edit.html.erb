<% content_for :main_class, "flex items-center justify-center min-h-screen" %>
<% content_for :title, "Nouveau mot de passe" %>

<div class="w-full max-w-sm px-4">
  <div class="text-center mb-8">
    <h1 class="text-2xl font-semibold text-white tracking-tight">Vigie</h1>
    <p class="text-gray-500 text-sm mt-1">Choisissez un nouveau mot de passe</p>
  </div>

  <div class="bg-gray-900 border border-gray-800 rounded-2xl p-8">
    <%= simple_form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :put }) do |f| %>
      <%= f.input_field :reset_password_token, as: :hidden %>

      <% if resource.errors.any? %>
        <div class="bg-red-950 border border-red-800 rounded-lg px-4 py-3 mb-5 text-sm text-red-300">
          <% resource.errors.full_messages.each do |msg| %>
            <p><%= msg %></p>
          <% end %>
        </div>
      <% end %>

      <div class="space-y-5">
        <div>
          <%= f.label :password, "Nouveau mot de passe", class: "block text-sm text-gray-400 mb-1.5" %>
          <%= f.input_field :password, as: :password,
              autofocus: true,
              autocomplete: "new-password",
              class: "w-full bg-gray-800 border border-gray-700 rounded-lg px-4 py-2.5 text-white placeholder-gray-600 focus:outline-none focus:border-yellow-400 transition-colors text-sm" %>
          <p class="text-xs text-gray-600 mt-1"><%= @minimum_password_length %> caractères minimum</p>
        </div>

        <div>
          <%= f.label :password_confirmation, "Confirmation", class: "block text-sm text-gray-400 mb-1.5" %>
          <%= f.input_field :password_confirmation, as: :password,
              autocomplete: "new-password",
              class: "w-full bg-gray-800 border border-gray-700 rounded-lg px-4 py-2.5 text-white placeholder-gray-600 focus:outline-none focus:border-yellow-400 transition-colors text-sm" %>
        </div>

        <%= f.submit "Réinitialiser le mot de passe",
            class: "w-full bg-yellow-400 hover:bg-yellow-300 text-gray-900 font-semibold rounded-lg px-4 py-2.5 transition-colors cursor-pointer text-sm" %>
      </div>
    <% end %>
  </div>
</div>
