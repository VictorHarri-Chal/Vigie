<% if pagy.pages > 1 %>
  <% prev_page = pagy.page > 1 ? pagy.page - 1 : nil %>
  <% next_page = pagy.page < pagy.pages ? pagy.page + 1 : nil %>
  <div class="flex items-center justify-between mt-4 text-xs">
    <% if prev_page %>
      <%= link_to "← Préc.", url_for(page_param => prev_page, tab: tab_index), class: "text-yellow-400 hover:text-yellow-300 transition-colors" %>
    <% else %>
      <span class="text-gray-700">← Préc.</span>
    <% end %>

    <span class="text-gray-500"><%= pagy.page %> / <%= pagy.pages %></span>

    <% if next_page %>
      <%= link_to "Suiv. →", url_for(page_param => next_page, tab: tab_index), class: "text-yellow-400 hover:text-yellow-300 transition-colors" %>
    <% else %>
      <span class="text-gray-700">Suiv. →</span>
    <% end %>
  </div>
<% end %>
