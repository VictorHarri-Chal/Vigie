<turbo-frame id="note-<%= incident.id %>">
  <% displayed = incident.payload&.dig("note").presence || incident.description %>
  <div data-controller="note">

    <%# État affichage %>
    <div data-note-target="display" class="flex items-start gap-2 group">
      <span class="text-xs text-gray-300 line-clamp-2 flex-1 leading-relaxed"><%= displayed %></span>
      <button
        data-action="click->note#edit"
        title="Modifier"
        class="flex-shrink-0 mt-0.5 opacity-0 group-hover:opacity-100 text-gray-600 hover:text-gray-400 transition-all cursor-pointer"
      >
        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
        </svg>
      </button>
    </div>

    <%# État édition %>
    <div data-note-target="form" class="hidden">
      <%= form_with url: update_note_incident_path(incident), method: :patch do |f| %>
        <%= f.text_area :note,
            value: displayed,
            rows: 3,
            placeholder: "Description de l'incident...",
            class: "w-full bg-gray-800 border border-gray-700 rounded-lg text-xs text-gray-200 px-3 py-2 resize-none focus:outline-none focus:border-gray-600 placeholder-gray-600 leading-relaxed" %>
        <div class="flex items-center gap-2 mt-2">
          <button type="submit" class="text-xs px-3 py-1.5 rounded-lg bg-yellow-400 text-gray-900 font-semibold hover:bg-yellow-300 transition-colors cursor-pointer">
            Enregistrer
          </button>
          <button type="button" data-action="click->note#cancel"
            class="text-xs px-3 py-1.5 rounded-lg bg-gray-800 border border-gray-700 text-gray-400 hover:text-white transition-colors cursor-pointer">
            Annuler
          </button>
        </div>
      <% end %>
    </div>

  </div>
</turbo-frame>
